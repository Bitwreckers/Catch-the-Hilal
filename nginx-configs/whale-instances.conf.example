# Whale Instance Subdomain — للتحديات الديناميكية
# الـ instances تعمل على subdomain مثل: uuid.jordancyberclub.com
# ضع هذا الـ server block أو أضفه لـ nginx
#
# شغّل: sudo cp whale-instances.conf.example /etc/nginx/sites-available/
# وفعّل: sudo ln -s ../sites-available/whale-instances.conf.example /etc/nginx/sites-enabled/
# ثم: sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name ~^[a-f0-9-]+\.jordancyberclub\.com$;

    location / {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
