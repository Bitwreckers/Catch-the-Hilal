# Copy this file to .env and set values for your environment.
# Do NOT commit .env to version control.

# ---------------------------------------------------------------------------
# Production / VPS: Set to your backend API URL (no trailing slash).
# Examples: https://api.yourdomain.com  or  http://YOUR_SERVER_IP:8000
# If empty, the app uses relative paths (same origin); use when frontend and
# backend are served from the same domain (e.g. single nginx).
# ---------------------------------------------------------------------------
# VITE_API_BASE_URL=

# Optional: Comma-separated user IDs that can access /admin (e.g. 1 or 1,2,3).
# These users will see the Admin link and can open the admin panel.
# VITE_ADMIN_USER_IDS=1

# Optional: CTF start time (ISO 8601 string) for display on landing page.
# VITE_CTF_START_TIME=2025-01-01T00:00:00Z
