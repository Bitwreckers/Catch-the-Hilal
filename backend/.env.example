# Backend (CTFd) environment variables for production.
# Copy to .env and set real values. Do NOT commit .env to version control.
#
# When using docker-compose, you can override these in the compose file
# or use: docker compose --env-file .env up -d

# Required for production (multi-worker). Use a long random string.
# SECRET_KEY=your-random-secret-key-here

# Database: full URL or use DATABASE_HOST + DATABASE_USER + etc.
# Example: mysql+pymysql://ctfd:STRONG_PASSWORD@db/ctfd
# DATABASE_URL=mysql+pymysql://ctfd:CHANGE_ME@db/ctfd

# Redis (used for cache). Example: redis://cache:6379
# REDIS_URL=redis://cache:6379

# Optional: set when behind a reverse proxy (e.g. Nginx).
# REVERSE_PROXY=true

# Optional: worker count for gunicorn (default 1).
# WORKERS=1
